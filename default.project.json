{
  "name": "TurnedBaseGame",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
       "Packages": {
        "$path": "Packages"
      },
      "Shared": {
        "$path": "src/shared",
        "$ignoreUnknownInstances": true
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
        
      }
    },

    "StarterPlayer": {
  
      "StarterPlayerScripts": {
      
        "Client": {
        
          "$path": "src/client"
          
        }
      }
    },

 

    "StarterGui": {
      "$className": "StarterGui"
     
    },


    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}